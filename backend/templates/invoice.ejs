<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Invoice</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: #333; margin: 40px; }
        .header { display: flex; justify-content: space-between; border-bottom: 2px solid #007bff; padding-bottom: 20px; }
        .logo { font-size: 28px; font-weight: bold; color: #007bff; }
        .invoice-details { text-align: right; }
        .details-section { margin-top: 40px; display: flex; justify-content: space-between; }
        .billing-to { width: 45%; }
        .billing-to h4 { margin-top: 0; color: #007bff; }
        table { width: 100%; border-collapse: collapse; margin-top: 40px; }
        th { background: #007bff; color: #fff; padding: 12px; text-align: left; }
        td { border-bottom: 1px solid #ddd; padding: 12px; }
        .totals { margin-top: 40px; text-align: right; }
        .totals div { margin-bottom: 10px; font-size: 16px; }
        .grand-total { font-weight: bold; font-size: 20px; color: #007bff; }
        .footer { margin-top: 60px; font-size: 12px; color: #777; text-align: center; }
    </style>
</head>
<body>
    <div class="header">
        <div class="logo">LINOTEC IT SOLUTIONS</div>
        <div class="invoice-details">
            <div style="font-weight: bold; font-size: 20px;">INVOICE</div>
            <div>No: <%= invoice_no %></div>
            <div>Date: <%= new Date(created_at).toLocaleDateString() %></div>
        </div>
    </div>

    <div class="details-section">
        <div class="billing-to">
            <h4>Billing To:</h4>
            <div><b><%= customer_name %></b></div>
            <div><%= company_name %></div>
            <div><%= customer_email %></div>
        </div>
        <div class="billing-to" style="text-align: right;">
            <h4>From:</h4>
            <div><b>Linotec IT Solutions</b></div>
            <div>123 Tech Park, Suite 400</div>
            <div>City, State, Zip</div>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th>Description</th>
                <th>Quantity</th>
                <th>Price</th>
                <th>Amount</th>
            </tr>
        </thead>
        <tbody>
            <% items.forEach(item => { %>
                <tr>
                    <td><%= item.description %></td>
                    <td><%= item.quantity %></td>
                    <td>$<%= item.unit_price %></td>
                    <td>$<%= item.amount %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>

    <div class="totals">
        <div>Subtotal: $<%= subtotal %></div>
        <div>Tax (<%= tax_percentage %>%): $<%= tax_amount %></div>
        <div class="grand-total">Total: $<%= total_amount %></div>
    </div>

    <div class="footer">
        Thank you for your business! Please pay this invoice within 15 days.
    </div>
</body>
</html>
